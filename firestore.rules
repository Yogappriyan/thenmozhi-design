rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // DENY ALL BY DEFAULT
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Authorized admin email check
      return isSignedIn() && (
        request.auth.token.email == 'designs2306@gmail.com' || 
        request.auth.token.email == 'vishwa10230506@gmail.com'
      ) && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Helper for products validation
    function isValidProduct(data) {
      return data.name is string && data.name.size() <= 500 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.images is list && data.images.size() > 0;
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true; // Publicly readable
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    // Orders Collection
    match /orders/{orderId} {
      // Admins can read all orders. Users can read only if they know the order ID (tracking)
      // Actually, for tracking, we might want to allow reading specific order if ID matches.
      // But we should protect PII.
      allow get: if true; // Tracking needs simple access, but let's be safer in production.
                         // For now, allow reading by ID for tracking.
      allow list: if isAdmin();
      
      allow create: if true; // Anonymous checkout
      allow update: if (isAdmin() || (
        // Allow customer to update order with UPI TXN ID maybe? 
        // For this app, let's say only admin updates status.
        false
      ));
      allow delete: if isAdmin();
    }
  }
}
