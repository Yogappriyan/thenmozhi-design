{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Store inventory items",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "category": { "type": "string" },
        "images": { "type": "array" },
        "sizes": { "type": "array" },
        "inventory": { "type": "number" },
        "featured": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "category", "images", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders",
      "type": "object",
      "properties": {
        "items": { "type": "array" },
        "customer": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string" },
            "phone": { "type": "string" },
            "address": { "type": "string" }
          }
        },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["placed", "processing", "shipped", "delivered"] },
        "paymentStatus": { "type": "string", "enum": ["pending", "confirmed"] },
        "orderId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["items", "customer", "total", "status", "paymentStatus", "orderId", "createdAt"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all available products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of all customer orders"
    }
  }
}
